#!/bin/sh

set -eu

message_file=$1
source_type=${2:-}

case "$source_type" in
  merge|squash|commit)
    exit 0
    ;;
esac

existing_message=$(
  sed -n '/^[[:space:]]*#/d; /^[[:space:]]*$/d; p; q' "$message_file" | tr -d '\r'
)

if [ -n "$existing_message" ]; then
  exit 0
fi

cat >"$message_file" <<'EOF'
# Format: type(scope): subject
#
# Allowed types:
#   feat, fix, refactor, docs, test, chore, build, ci, perf, style, revert
#
# Examples:
#   feat(retrieval): add reranker fallback path
#   fix(ui): handle empty citations in answer panel
#   refactor(agent)!: simplify routing state transitions
#
# Write the actual commit title below this comment block.
EOF
