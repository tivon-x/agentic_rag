# OpenAI configuration using OpenAI or compatible API
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_MODEL=gpt-5-mini

# Preferred app key (alias to OPENAI_API_MODEL)
LLM_MODEL=gpt-5-mini

# Optional per-task model overrides (multi-model architecture)
LLM_MODEL_RESEARCH_SEARCH=gpt-5
LLM_MODEL_DECIDE_RETRIEVAL=gpt-5-mini
LLM_MODEL_REWRITE_QUERY=gpt-5-mini
LLM_MODEL_SUMMARIZE_HISTORY=gpt-5-nano
LLM_MODEL_AGGREGATE_ANSWERS=gpt-5-mini

# Backward-compatible generic keys (optional)
LLM_MODEL_DECISION=gpt-5-mini
LLM_MODEL_REWRITE=gpt-5-mini
LLM_MODEL_SUMMARIZE=gpt-5-nano
LLM_MODEL_AGGREGATE=gpt-5-mini

# Embedding model configuration using OpenAI-compatible API
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
EMBEDDING_DIMENSION=1024
EMBEDDING_API_BASE=https://api.openai.com/v1
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=your_openai_api_key_here

# Application configuration
